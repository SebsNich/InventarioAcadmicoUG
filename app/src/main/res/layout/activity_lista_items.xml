<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- Encabezado azul -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1565C0"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦 Inventario UG"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Materiales registrados"
            android:textColor="#BBDEFB"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Barra de búsqueda -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1976D2"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="12dp">

        <EditText
            android:id="@+id/etBuscar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="🔍  Buscar por nombre o categoría..."
            android:inputType="text"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:textSize="14sp"
            android:textColor="#212121"
            android:textColorHint="#9E9E9E"/>
    </LinearLayout>

    <!-- Lista -->
    <ListView
        android:id="@+id/lvInventario"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#DDEEFF"
        android:dividerHeight="1dp"/>

    <!-- Mensaje vacío -->
    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="😕 No se encontraron materiales"
        android:textAlignment="center"
        android:textColor="#9E9E9E"
        android:textSize="16sp"
        android:padding="40dp"
        android:visibility="gone"/>

</LinearLayout>