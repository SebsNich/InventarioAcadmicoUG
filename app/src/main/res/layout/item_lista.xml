<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="@dimen/spacing_md"
    android:gravity="center_vertical">

    <!-- Franja izquierda color UG -->
    <View
        android:layout_width="4dp"
        android:layout_height="56dp"
        android:background="@color/ug_amarillo"
        android:layout_marginEnd="@dimen/spacing_md"/>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/ug_azul_reflex"/>

        <TextView
            android:id="@+id/tvCategoriaItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/ug_azul_process"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvCantidadItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_badge_blue"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Flecha -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_chevron_right"
        android:contentDescription="@string/btn_listar"/>

</LinearLayout>