<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ug_fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/ug_azul_reflex"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/titulo_registro"
                android:textColor="@color/white"
                android:textSize="@dimen/title_size"
                android:layout_marginTop="15dp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/subtitulo_registro"
                android:textColor="@color/ug_azul_suave"
                android:textSize="@dimen/subtitle_size"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_nombre"
                    android:textColor="@color/ug_azul_marino"
                    android:textSize="@dimen/label_size"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_edit_text"
                    android:hint="@string/hint_nombre"
                    android:autofillHints="off"
                    android:textColorHint="@color/ug_azul_suave"
                    android:inputType="textCapSentences"
                    android:minHeight="@dimen/button_min_height"
                    android:padding="12dp"
                    android:textColor="@color/black"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/label_categoria"
                    android:textColor="@color/ug_azul_marino"
                    android:textSize="@dimen/label_size"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_edit_text"
                    android:hint="@string/hint_categoria"
                    android:autofillHints="off"
                    android:textColorHint="@color/ug_azul_suave"
                    android:inputType="textCapSentences"
                    android:minHeight="@dimen/button_min_height"
                    android:padding="12dp"
                    android:textColor="@color/black"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/label_cantidad"
                    android:textColor="@color/ug_azul_marino"
                    android:textSize="@dimen/label_size"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etCantidad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_edit_text"
                    android:hint="@string/hint_cantidad"
                    android:autofillHints="off"
                    android:textColorHint="@color/ug_azul_suave"
                    android:inputType="number"
                    android:minHeight="@dimen/button_min_height"
                    android:padding="12dp"
                    android:textColor="@color/black"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/label_ubicacion"
                    android:textColor="@color/ug_azul_marino"
                    android:textSize="@dimen/label_size"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etUbicacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_edit_text"
                    android:hint="@string/hint_ubicacion"
                    android:autofillHints="off"
                    android:textColorHint="@color/ug_azul_suave"
                    android:inputType="textCapSentences"
                    android:minHeight="@dimen/button_min_height"
                    android:padding="12dp"
                    android:textColor="@color/black"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/label_observacion"
                    android:textColor="@color/ug_azul_marino"
                    android:textSize="@dimen/label_size"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etObservacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_edit_text"
                    android:hint="@string/hint_observacion"
                    android:autofillHints="off"
                    android:textColorHint="@color/ug_azul_suave"
                    android:inputType="textMultiLine"
                    android:minHeight="@dimen/button_min_height"
                    android:lines="3"
                    android:gravity="top"
                    android:padding="12dp"
                    android:textColor="@color/black"/>

                <Button
                    android:id="@+id/btnGuardar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_btn_amarillo"
                    android:text="@string/btn_guardar"
                    android:textAllCaps="false"
                    android:textColor="@color/ug_azul_reflex"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>